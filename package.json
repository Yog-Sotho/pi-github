{
  "name": "pi-github-agent",
  "version": "2.1.0",
  "description": "Streaming NDJSON GitHub tool bridge for AI coding agents (Pi, Claude Code, and others)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "pi-github": "./dist/cli.js"
  },
  "files": [
    "dist",
    "extensions",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "tsx watch src/cli.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src tests",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "npm run typecheck && npm run lint && npm run test && npm run build"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@octokit/plugin-retry": "^6.1.0",
    "@octokit/plugin-throttling": "^8.2.0",
    "@octokit/rest": "^20.1.1",
    "commander": "^12.1.0",
    "opossum": "^8.1.4",
    "pino": "^9.1.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.2",
    "@types/opossum": "^8.1.8",
    "@vitest/coverage-v8": "^1.6.0",
    "eslint": "^9.30.0",
    "msw": "^2.3.1",
    "pino-pretty": "^11.2.1",
    "prettier": "^3.3.2",
    "tsx": "^4.16.0",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.35.0",
    "vitest": "^1.6.0"
  },
  "keywords": [
    "github",
    "ai-agent",
    "pi-coding-agent",
    "cli",
    "coding-assistant",
    "octokit",
    "ndjson",
    "streaming"
  ],
  "license": "MIT",
  "author": "YogSotho",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Yog-Sotho/pi-github.git"
  },
  "homepage": "https://github.com/Yog-Sotho/pi-github#readme",
  "bugs": {
    "url": "https://github.com/Yog-Sotho/pi-github/issues"
  }
}
