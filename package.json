{
  "name": "pi-github-agent",
  "version": "2.0.0",
  "description": "Military-grade, streaming GitHub integration protocol for AI coding agents",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "pi-github": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "dev": "tsx watch src/cli.ts",
    "build": "tsc && tsc-alias",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src tests",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "npm run typecheck && npm run lint && npm run test:coverage && npm run build"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@octokit/rest": "^20.1.1",
    "@octokit/plugin-retry": "^6.1.0",
    "@octokit/plugin-throttling": "^8.2.0",
    "commander": "^12.1.0",
    "zod": "^3.23.8",
    "pino": "^9.1.0",
    "pino-pretty": "^11.2.1",
    "opossum": "^8.1.4",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.14.2",
    "@types/uuid": "^9.0.8",
    "@types/opossum": "^8.1.8",
    "typescript": "^5.4.5",
    "tsc-alias": "^1.8.10",
    "eslint": "^8.57.0",
    "@typescript-eslint/parser": "^7.13.0",
    "@typescript-eslint/eslint-plugin": "^7.13.0",
    "prettier": "^3.3.2",
    "vitest": "^1.6.0",
    "@vitest/coverage-v8": "^1.6.0",
    "tsx": "^4.16.0",
    "msw": "^2.3.1"
  },
  "keywords": ["github", "ai-agent", "cli", "coding-assistant", "octokit", "ndjson", "streaming"],
  "license": "MIT"
}